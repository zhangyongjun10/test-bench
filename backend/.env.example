# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/testbench

# ClickHouse 配置（默认从数据库读取，这里是默认值）
CLICKHOUSE_ENDPOINT=clickhouse:9000
CLICKHOUSE_DATABASE=opik
CLICKHOUSE_USERNAME=opik
CLICKHOUSE_PASSWORD=opik
CLICKHOUSE_SOURCE_TYPE=opik

# 加密密钥，请在生产环境更换（32 bytes base64 编码）
ENCRYPTION_KEY=your-encryption-key-change-in-production

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 数据保留天数
DATA_RETENTION_DAYS=30

# Agent 调用超时（秒）
AGENT_TIMEOUT_SECONDS=1200

# 数据库连接池常驻连接数
DB_POOL_SIZE=20

# 数据库连接池临时溢出连接数
DB_MAX_OVERFLOW=30

# 获取数据库连接的等待秒数
DB_POOL_TIMEOUT=30

# 数据库空闲连接回收秒数
DB_POOL_RECYCLE_SECONDS=1800

# 并发执行链路同一时刻进入数据库读写区的最大协程数
CONCURRENT_EXECUTION_DB_CONCURRENCY=20

# 并发执行单批次最大允许下发的 Agent 调用数
CONCURRENT_EXECUTION_MAX_CONCURRENCY=200
